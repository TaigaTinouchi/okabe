# クライアント認証用の静的トークン。生成例: openssl rand -base64 32
AUTH_TOKEN=

# 待ち受けポート（省略時 8787）
PORT=8787

# バインド先（省略時 127.0.0.1 = 外部非公開。公開は Caddy 経由のみ）
# LAN内の他端末から直接叩きたい開発時のみ 0.0.0.0 に
# BIND_HOST=127.0.0.1

# SQLite ファイルのパス（省略時 data/okabe.db）
DB_PATH=data/okabe.db

# --- LLM (M2) ---
# 未設定の場合はエコー応答で起動する（M1 相当の動作確認用）
ANTHROPIC_API_KEY=

# 使用モデル（省略時 claude-sonnet-4-6。Opus はコスト増と引き換えの明示オプトイン）
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Google カレンダー (M3) ---
# 3つ揃うと calendar スキルが有効になる。取得手順は README の
# 「M3: Google カレンダー連携のセットアップ」を参照
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# 対象カレンダー（省略時 primary）
# GOOGLE_CALENDAR_ID=primary

# --- ジョブ (M4) ---
# 軽タスク（毎朝サマリーの整形など）用モデル（省略時 claude-haiku-4-5）
# ANTHROPIC_MODEL_LIGHT=claude-haiku-4-5

# 毎朝サマリーの実行時刻（cron式・Asia/Tokyo。省略時 7:30）
# MORNING_SUMMARY_CRON=30 7 * * *

# 無効化するジョブ（カンマ区切り）。例: DISABLED_JOBS=morning-summary
# DISABLED_JOBS=
