# クライアント認証用の静的トークン。生成例: openssl rand -base64 32
AUTH_TOKEN=

# 待ち受けポート（省略時 8787）
PORT=8787

# SQLite ファイルのパス（省略時 data/okabe.db）
DB_PATH=data/okabe.db

# --- LLM (M2) ---
# 未設定の場合はエコー応答で起動する（M1 相当の動作確認用）
ANTHROPIC_API_KEY=

# 使用モデル（省略時 claude-opus-4-8）
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Google カレンダー (M3) ---
# 3つ揃うと calendar スキルが有効になる。取得手順は README の
# 「M3: Google カレンダー連携のセットアップ」を参照
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# 対象カレンダー（省略時 primary）
# GOOGLE_CALENDAR_ID=primary
